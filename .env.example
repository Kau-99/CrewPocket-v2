# ── Firebase (client SDK — públicos por design, NÃO são segredos) ──────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# App Check (reCAPTCHA v3). Debug token: APENAS em dev.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
NEXT_PUBLIC_APPCHECK_DEBUG_TOKEN=

# URL pública do app (success/cancel do Stripe, links de PDF)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# "true" conecta o client SDK aos emulators locais
NEXT_PUBLIC_USE_EMULATORS=true

# ── Firebase Admin (SEGREDOS — somente servidor, nunca NEXT_PUBLIC_) ───────
# Service account: Firebase Console → Project Settings → Service Accounts
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Manter os \n literais da chave (o código converte)
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Stripe (SEGREDOS — somente servidor) ───────────────────────────────────
STRIPE_SECRET_KEY=
# `stripe listen --forward-to localhost:3000/api/stripe/webhook` imprime o whsec_
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_SOLO_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# ── Resend (e-mails transacionais — OPCIONAL) ──────────────────────────────
# Sem isto, o reset de senha usa o envio padrão do Firebase (cai no spam).
# RESEND_API_KEY: painel do Resend → API Keys. RESEND_FROM: remetente de um
# domínio verificado no Resend, ex.: "CrewPocket <noreply@seudominio.com>".
# Para testar, o Resend deixa enviar de "onboarding@resend.dev" só p/ o e-mail
# dono da conta. Requer também o service account real do Firebase Admin.
RESEND_API_KEY=
RESEND_FROM=
