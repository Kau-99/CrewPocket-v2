rules_version = '2';

// Fase 0: lockdown total (fallback obrigatório da SPEC §6.3).
// As regras por coleção, espelhando os Zod schemas, entram na Fase 2
// junto com a matriz de testes em @firebase/rules-unit-testing.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
